# Repo-root ignores. The Astro app under web/ has its own .gitignore too.
# (Replaced the legacy Python/Wagtail template — its `lib/` rule was ignoring web/src/lib.)

# Dependencies
node_modules/

# Build output
dist/
build/
.astro/

# Cloudflare / Wrangler local state
.wrangler/

# Environment & secrets
.env
.env.*
.dev.vars
.dev.vars.*

# Logs & debug
*.log
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS & editor cruft
.DS_Store
Thumbs.db
.idea/
*.swp
