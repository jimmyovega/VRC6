{
  "name": "web",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e:setup": "npm run build && npm run db:migrate:local && npm run db:seed:local",
    "test:e2e": "playwright test",
    "db:migrate:local": "wrangler d1 migrations apply vrc6-db --local",
    "db:seed:local": "wrangler d1 execute vrc6-db --local --file ./seed.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.1",
    "astro": "^7.0.3",
    "drizzle-orm": "^0.45.2",
    "wrangler": "^4.105.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "drizzle-kit": "^0.31.10",
    "vitest": "~3.2.0"
  }
}
