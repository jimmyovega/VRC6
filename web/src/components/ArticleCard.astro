---
// A standard article card, reused on the home page and category pages.
// Fixed height with clamped title/excerpt so cards stay uniform regardless of
// text length. An optional cover thumbnail bleeds to the card's top edge
// (M4 Phase D).
interface Props {
  title: string;
  excerpt?: string | null;
  slug: string;
  category?: string | null;
  coverUrl?: string | null;
}
const { title, excerpt, slug, category, coverUrl } = Astro.props;
---

<a class="card article" href={`/articles/${slug}`}>
  {
    coverUrl && (
      <div class="card-cover">
        <img src={coverUrl} alt="" loading="lazy" />
      </div>
    )
  }
  {category && <span class="cat pixel">{category}</span>}
  <h3 class="pixel card-title">{title}</h3>
  {excerpt && <p class="card-excerpt">{excerpt}</p>}
</a>

<style>
  .article {
    height: var(--card-h, 165px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .card-cover {
    flex: 0 0 auto;
    height: 70px;
    /* bleed to the card's edges (which has 1.25rem padding) */
    margin: -1.25rem -1.25rem 0.6rem;
  }
  .card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-title {
    font-size: 0.7rem;
    line-height: 1.5;
    margin: 0 0 0.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-excerpt {
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
