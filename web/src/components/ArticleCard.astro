---
// A standard article card, reused on the home page and category pages.
// Fixed height with clamped title/excerpt so cards stay uniform regardless of
// text length. With a cover it mirrors the featured hero: the image is a
// full-bleed, cropped background behind the text under a gradient scrim
// (M4 Phase D + cover polish). Coverless cards keep the plain layout.
interface Props {
  title: string;
  excerpt?: string | null;
  slug: string;
  category?: string | null;
  coverUrl?: string | null;
  coverFocus?: string | null;
}
const { title, excerpt, slug, category, coverUrl, coverFocus } = Astro.props;
---

<a
  class:list={["card", "article", { "has-cover": !!coverUrl }]}
  href={`/articles/${slug}`}
>
  {
    coverUrl && (
      <img
        class="card-cover-img"
        src={coverUrl}
        alt=""
        loading="lazy"
        style={coverFocus ? `object-position:${coverFocus}` : undefined}
      />
    )
  }
  <div class="card-body">
    {category && <span class="cat pixel">{category}</span>}
    <h3 class="pixel card-title">{title}</h3>
    {excerpt && <p class="card-excerpt">{excerpt}</p>}
  </div>
</a>

<style>
  .article {
    position: relative;
    height: var(--card-h, 165px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
  }
  .card-cover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* object-position is set inline from the article's stored focal point */
    display: block;
  }
  .card-body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
  }
  /* Coverless: body fills the card, text reads from the top as before. */
  .article:not(.has-cover) .card-body {
    flex: 1;
  }
  /* With a cover: text sits at the bottom over a scrim so it stays legible. */
  .article.has-cover {
    justify-content: flex-end;
  }
  .article.has-cover .card-body {
    padding-top: 2.5rem;
    background: linear-gradient(
      to top,
      rgba(2, 12, 6, 0.92) 0%,
      rgba(2, 12, 6, 0.78) 55%,
      rgba(2, 12, 6, 0) 100%
    );
  }
  /* Reserve exactly two lines for the title (and, on coverless cards, the
     excerpt) so every card's text block is the same height even when the copy
     is only one line — keeps the feed's rows visually aligned. */
  .card-title {
    font-size: 0.7rem;
    line-height: 1.5;
    margin: 0 0 0.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 3em; /* 2 lines @ line-height 1.5 */
  }
  .card-excerpt {
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article:not(.has-cover) .card-excerpt {
    min-height: 3.2em; /* 2 lines @ line-height 1.6 */
  }
  /* Over an image: lighten the excerpt for legibility and keep it to one line
     so tag + title + excerpt fit the fixed card height without clipping. */
  .article.has-cover .card-excerpt {
    color: var(--phosphor);
    -webkit-line-clamp: 1;
    line-clamp: 1;
  }
</style>
