---
import { and, desc, eq, gt, like, ne } from "drizzle-orm";
import { alias } from "drizzle-orm/sqlite-core";
import { env } from "cloudflare:workers";
import Layout from "../../layouts/Layout.astro";
import { getDb, schema } from "../../db";
import { getArticleStatusCounts, getArticlesForReview, getUserStatusCounts } from "../../db/queries";
import { getMaintenanceStatus } from "../../lib/maintenance";

// Admin-only — enforced in middleware.
const me = Astro.locals.user!;
const db = getDb(env.DB);
const [pendingReview, maintenance, articleCounts, userCounts] = await Promise.all([
  getArticlesForReview(db),
  getMaintenanceStatus(db),
  getArticleStatusCounts(db),
  getUserStatusCounts(db),
]);

// Last few audit entries — same shape as the full /admin/audit page.
const actorAlias = alias(schema.user, "actor");
const targetAlias = alias(schema.user, "target");
const recentActivity = await db
  .select({
    id: schema.audits.id,
    action: schema.audits.action,
    createdAt: schema.audits.createdAt,
    actorEmail: actorAlias.email,
    targetEmail: targetAlias.email,
  })
  .from(schema.audits)
  .leftJoin(actorAlias, eq(schema.audits.actorId, actorAlias.id))
  .leftJoin(targetAlias, eq(schema.audits.targetUserId, targetAlias.id))
  .orderBy(desc(schema.audits.createdAt))
  .limit(5);
const fmt = (d: Date | null) =>
  d ? new Date(d).toISOString().replace("T", " ").slice(0, 19) + "Z" : "";
// Soft-deleted accounts are hidden to keep the list clean; re-inviting their
// email revives them.
const users = await db
  .select({
    id: schema.user.id,
    name: schema.user.name,
    email: schema.user.email,
    role: schema.user.role,
    status: schema.user.status,
  })
  .from(schema.user)
  .where(ne(schema.user.status, "deleted"))
  .orderBy(schema.user.email);

// Which pending users still have a live activation link (unexpired reset token)?
const liveTokens = await db
  .select({ userId: schema.verification.value })
  .from(schema.verification)
  .where(
    and(
      like(schema.verification.identifier, "reset-password:%"),
      gt(schema.verification.expiresAt, new Date()),
    ),
  );
const hasLiveLink = new Set(liveTokens.map((t) => t.userId));
---

<Layout center topShare={1} bottomShare={3} title="Admin — VRC6">
  <div class="prose admin">
    <h1 class="page-title pixel">Admin</h1>
    <p>Welcome, <strong>{me.name}</strong>.</p>

    <h2 class="section pixel">CONTENT &amp; USERS</h2>
    <div class="stats-grid">
      <div class="stat-box card">
        <span class="stat-n pixel">{articleCounts.published}</span>
        <span class="stat-label pixel">PUBLISHED</span>
      </div>
      <div class="stat-box card">
        <span class="stat-n pixel">{articleCounts.pending_review}</span>
        <span class="stat-label pixel">PENDING REVIEW</span>
      </div>
      <div class="stat-box card">
        <span class="stat-n pixel">{articleCounts.draft}</span>
        <span class="stat-label pixel">DRAFTS</span>
      </div>
      <div class="stat-box card">
        <span class="stat-n pixel">{userCounts.active}</span>
        <span class="stat-label pixel">ACTIVE USERS</span>
      </div>
      <div class="stat-box card">
        <span class="stat-n pixel">{userCounts.pending_activation}</span>
        <span class="stat-label pixel">PENDING INVITES</span>
      </div>
      <div class="stat-box card">
        <span class="stat-n pixel">{userCounts.suspended}</span>
        <span class="stat-label pixel">SUSPENDED</span>
      </div>
    </div>

    <h2 class="section pixel">RECENT ACTIVITY</h2>
    {
      recentActivity.length === 0 ? (
        <p class="muted">No audit entries yet.</p>
      ) : (
        <div class="activity">
          {recentActivity.map((r) => (
            <div class="activity-row card">
              <span class="when pixel">{fmt(r.createdAt)}</span>
              <span class="action pixel">{r.action}</span>
              <span class="who">
                {r.actorEmail ?? "system"}
                {r.targetEmail ? ` → ${r.targetEmail}` : ""}
              </span>
            </div>
          ))}
        </div>
      )
    }
    <p><a class="btn pixel review-link" href="/admin/audit">VIEW FULL AUDIT LOG →</a></p>

    <h2 class="section pixel">SITE STATUS</h2>
    <div class="card site-status">
      <p class="status-line pixel">
        Public site is <span class={maintenance.enabled ? "st-on" : "st-off"}>
          {maintenance.enabled ? "UNDER MAINTENANCE" : "LIVE"}
        </span>
      </p>
      <p class="muted">
        {maintenance.enabled
          ? "Anonymous visitors see a “back soon” page. Signed-in users (you, editors) still see the real site."
          : "Everything you publish is visible to the public immediately. Turn maintenance on before testing on production."}
      </p>
      <form id="maintenance-form" class="maint-form">
        <label class="field">
          <span class="label pixel">MESSAGE (optional)</span>
          <input
            type="text"
            name="message"
            maxlength="300"
            placeholder="VRC6 is doing some quick upkeep. Check back shortly."
            value={maintenance.message ?? ""}
          />
        </label>
        <button
          class={`btn pixel ${maintenance.enabled ? "" : "maint-on-btn"}`}
          type="submit"
          data-enable={(!maintenance.enabled).toString()}
        >
          {maintenance.enabled ? "TURN MAINTENANCE OFF" : "TURN MAINTENANCE ON"}
        </button>
      </form>
      <p class="result pixel" id="maintenance-result" hidden></p>
    </div>

    <h2 class="section pixel">REVIEW QUEUE</h2>
    <a class="btn pixel review-link" href="/admin/review">
      {pendingReview.length} ARTICLE{pendingReview.length === 1 ? "" : "S"} AWAITING REVIEW →
    </a>

    <h2 class="section pixel">ALL ARTICLES</h2>
    <a class="btn pixel review-link" href="/admin/articles">
      Browse, filter, unpublish, feature, or delete any article →
    </a>

    <h2 class="section pixel">INVITE A USER</h2>
    <form id="invite-form" class="card invite-card">
      <label class="field">
        <span class="label pixel">EMAIL</span>
        <input type="email" name="email" required autocomplete="off" />
      </label>
      <label class="field">
        <span class="label pixel">NAME</span>
        <input type="text" name="name" autocomplete="off" />
      </label>
      <label class="field">
        <span class="label pixel">ROLE</span>
        <select name="role">
          <option value="editor">Editor</option>
          <option value="admin">Admin</option>
        </select>
      </label>
      <p class="result pixel" id="invite-result" hidden></p>
      <button class="btn pixel submit" type="submit">SEND INVITE</button>
    </form>

    <h2 class="section pixel">USERS</h2>
    <div class="users">
      {
        users.map((u) => (
          <div class="user-row card">
            <div class="u-meta">
              <span class="u-name">{u.name}</span>
              <span class="u-email">{u.email}</span>
            </div>
            <div class="u-tags pixel">
              <span class={`tagpill role-${u.role}`}>{u.role.toUpperCase()}</span>
              <span class={`tagpill st-${u.status}`}>
                {u.status.replace(/_/g, " ").toUpperCase()}
              </span>
              {u.status === "pending_activation" && (
                <span class={`tagpill ${hasLiveLink.has(u.id) ? "link-ok" : "link-dead"}`}>
                  {hasLiveLink.has(u.id) ? "LINK ACTIVE" : "LINK EXPIRED"}
                </span>
              )}
            </div>
            <div class="u-actions">
              {u.status === "suspended" ? (
                <button class="u-act pixel" data-id={u.id} data-action="reactivate">
                  REACTIVATE
                </button>
              ) : (
                u.status !== "deleted" && u.id !== me.id && (
                  <button class="u-act pixel" data-id={u.id} data-action="suspend">
                    SUSPEND
                  </button>
                )
              )}
              {(u.status === "pending_activation" || u.status === "expired") && (
                <button class="u-act pixel" data-id={u.id} data-action="resend">
                  RESEND ACTIVATION
                </button>
              )}
              {u.status !== "deleted" && u.id !== me.id && (
                <button
                  class="u-act pixel"
                  data-id={u.id}
                  data-action="setRole"
                  data-role={u.role === "admin" ? "editor" : "admin"}
                >
                  {u.role === "admin" ? "MAKE EDITOR" : "MAKE ADMIN"}
                </button>
              )}
              {u.status !== "deleted" && u.id !== me.id && (
                <button class="u-act danger pixel" data-id={u.id} data-action="delete">
                  DELETE
                </button>
              )}
              {u.id === me.id && <span class="u-self pixel">YOU</span>}
            </div>
          </div>
        ))
      }
    </div>

    <h2 class="section pixel">MAINTENANCE</h2>
    <div class="maint">
      <button class="btn pixel" id="run-expiry">RUN ACTIVATION EXPIRY</button>
    </div>
    <p class="result pixel" id="expiry-result" hidden></p>

    <p><a class="btn pixel back-link" href="/dashboard">BACK TO DASHBOARD</a></p>
  </div>
</Layout>

<script>
  const inviteForm = document.getElementById("invite-form") as HTMLFormElement | null;
  const inviteResult = document.getElementById("invite-result");
  inviteForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(inviteForm);
    const res = await fetch("/api/admin/invite", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        email: data.get("email"),
        name: data.get("name"),
        role: data.get("role"),
      }),
    });
    if (!inviteResult) return;
    inviteResult.hidden = false;
    if (res.ok) {
      inviteResult.textContent = "Invite sent — they'll get an activation email.";
      inviteResult.classList.remove("err");
      inviteForm.reset();
      // Refresh so the users list reflects the new/revived invite.
      setTimeout(() => location.reload(), 1000);
    } else {
      const j = (await res.json().catch(() => ({}))) as { error?: string };
      inviteResult.textContent = j.error ?? "Could not send invite.";
      inviteResult.classList.add("err");
    }
  });

  const maintenanceForm = document.getElementById("maintenance-form") as HTMLFormElement | null;
  const maintenanceResult = document.getElementById("maintenance-result");
  maintenanceForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const submitBtn = maintenanceForm.querySelector("button");
    const enabled = submitBtn?.dataset.enable === "true";
    const message = String(new FormData(maintenanceForm).get("message") ?? "").trim();
    const res = await fetch("/api/admin/maintenance", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ enabled, message }),
    });
    if (!maintenanceResult) return;
    maintenanceResult.hidden = false;
    if (res.ok) {
      maintenanceResult.textContent = enabled
        ? "Maintenance mode is now ON."
        : "Maintenance mode is now OFF.";
      maintenanceResult.classList.remove("err");
      setTimeout(() => location.reload(), 800);
    } else {
      const j = (await res.json().catch(() => ({}))) as { error?: string };
      maintenanceResult.textContent = j.error ?? "Could not update maintenance mode.";
      maintenanceResult.classList.add("err");
    }
  });

  const expiryBtn = document.getElementById("run-expiry");
  const expiryResult = document.getElementById("expiry-result");
  expiryBtn?.addEventListener("click", async () => {
    const res = await fetch("/api/admin/run-expiry", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
    });
    const j = (await res.json().catch(() => ({}))) as { expired?: number; error?: string };
    if (!expiryResult) return;
    expiryResult.hidden = false;
    expiryResult.classList.toggle("err", !res.ok);
    expiryResult.textContent = res.ok
      ? `Expiry sweep complete — ${j.expired ?? 0} account(s) expired.`
      : (j.error ?? "Could not run expiry.");
    if (res.ok && (j.expired ?? 0) > 0) setTimeout(() => location.reload(), 1200);
  });

  document.querySelectorAll<HTMLButtonElement>(".u-act").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const action = btn.dataset.action;
      if (action === "delete" && !confirm("Delete this user?")) return;
      // The resend action targets its own endpoint; everything else is a user-action.
      const endpoint =
        action === "resend" ? "/api/admin/resend-invite" : "/api/admin/user-action";
      const payload =
        action === "resend"
          ? { userId: btn.dataset.id }
          : { userId: btn.dataset.id, action, role: btn.dataset.role };
      const res = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (res.ok) {
        if (action === "resend") alert("A fresh activation link has been sent.");
        location.reload();
      } else {
        const j = (await res.json().catch(() => ({}))) as { error?: string };
        alert(j.error ?? "Action failed.");
      }
    });
  });
</script>

<style>
  .admin {
    /* width:100% so the boxes fill a stable 720px regardless of content —
       otherwise margin:auto on the flex item shrinks it to fit its widest row. */
    width: 100%;
    max-width: 720px;
    margin-inline: auto;
  }
  .section {
    font-size: 0.7rem;
    color: var(--lime);
    margin: 1.75rem 0 0.75rem;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 0.75rem;
  }
  .stat-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 0.85rem 0.5rem;
    text-align: center;
  }
  .stat-n {
    font-size: 1.4rem;
    color: var(--phosphor);
  }
  .stat-label {
    font-size: 0.4rem;
    color: var(--lime);
  }
  .activity {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .activity-row {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: baseline;
    gap: 0.6rem 0.85rem;
    padding: 0.6rem 0.85rem;
  }
  .activity-row .when {
    font-size: 0.45rem;
    color: var(--lime);
    white-space: nowrap;
  }
  .activity-row .action {
    font-size: 0.5rem;
    color: var(--phosphor);
    white-space: nowrap;
  }
  .activity-row .who {
    color: var(--phosphor);
    font-size: 0.85rem;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .invite-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .maint {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .maint .btn {
    text-decoration: none;
    cursor: pointer;
  }
  .review-link {
    display: inline-block;
    text-decoration: none;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field .label {
    font-size: 0.5rem;
    color: var(--lime);
  }
  .field input,
  .field select {
    background: var(--deep-moss);
    border: 2px solid var(--lime);
    color: var(--phosphor);
    padding: 0.6rem;
    font-family: inherit;
    font-size: 0.95rem;
  }
  .field input:focus,
  .field select:focus {
    outline: none;
    border-color: var(--phosphor);
  }
  .result {
    font-size: 0.5rem;
    color: var(--lime);
    margin: 0;
  }
  .result.err {
    color: #fca5a5;
  }

  .site-status {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .status-line {
    font-size: 0.6rem;
  }
  .st-on {
    color: #fca5a5;
  }
  .st-off {
    color: var(--lime);
  }
  .maint-form {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.75rem;
    margin: 0;
  }
  .maint-form .field {
    flex: 1 1 260px;
  }
  .maint-on-btn {
    background: #fca5a5;
  }

  .users {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .user-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
  }
  .u-meta {
    display: flex;
    flex-direction: column;
    flex: 1 1 180px;
    min-width: 0;
  }
  .u-name {
    color: var(--phosphor);
  }
  .u-email {
    color: var(--lime);
    font-size: 0.8rem;
  }
  .u-tags {
    display: flex;
    gap: 0.4rem;
  }
  .tagpill {
    font-size: 0.4rem;
    padding: 0.3rem 0.45rem;
    background: var(--deep-moss);
    color: var(--phosphor);
    border: 1px solid var(--lime);
  }
  .st-suspended,
  .st-deleted,
  .link-dead {
    color: #fca5a5;
    border-color: #fca5a5;
  }
  .link-ok {
    color: var(--phosphor);
    border-color: var(--phosphor);
  }
  .u-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .u-act {
    font-size: 0.4rem;
    padding: 0.4rem 0.55rem;
    background: var(--lime);
    color: var(--deep-moss);
    border: 2px solid var(--phosphor);
    cursor: pointer;
  }
  .u-act.danger {
    background: var(--deep-moss);
    color: #fca5a5;
    border-color: #fca5a5;
  }
  .u-self {
    font-size: 0.4rem;
    color: var(--lime);
    align-self: center;
    opacity: 0.75;
  }
  .submit,
  .back-link {
    display: inline-block;
    text-align: center;
    cursor: pointer;
    text-decoration: none;
    margin-top: 1.75rem;
  }
</style>
