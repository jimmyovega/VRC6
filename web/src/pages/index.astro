---
// VRC6 front page — bento grid of published articles, read live from D1.
import { env } from "cloudflare:workers";
import ArticleCard from "../components/ArticleCard.astro";
import Layout from "../layouts/Layout.astro";
import { getDb } from "../db";
import { getCategories, getPublishedArticles } from "../db/queries";

const db = getDb(env.DB);
const published = await getPublishedArticles(db);
const categories = await getCategories(db);

const [featured, ...rest] = published;
---

<Layout>
  <div class="bento">
    <!-- Left column -->
    <section class="col">
      {
        featured && (
          <a class="card featured" href={`/articles/${featured.slug}`}>
            <span class="tag pixel">FEATURED</span>
            <h2 class="pixel feat-title">{featured.title}</h2>
            <p>{featured.excerpt}</p>
            <span class="more pixel">READ MORE &gt;&gt;</span>
          </a>
        )
      }
      <a class="card donate" href="/donate">
        <h3 class="pixel donate-title">SUPPORT VRC6</h3>
        <p>Help us keep alternative voices alive</p>
        <span class="btn pixel">DONATE NOW</span>
      </a>
    </section>

    <!-- Right column -->
    <section class="col grid-right">
      {
        rest.map((a) => (
          <ArticleCard
            title={a.title}
            excerpt={a.excerpt}
            slug={a.slug}
            category={a.category}
          />
        ))
      }
      <div class="card topics">
        <h3 class="pixel topics-title">BROWSE TOPICS</h3>
        <div class="chips">
          {
            categories.map((c) => (
              <a class="chip pixel" href={`/category/${c.slug}`}>
                {c.label.toUpperCase()}
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 900px) {
    .bento {
      grid-template-columns: 1fr 1fr;
    }
  }
  .col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .grid-right {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .featured {
    flex: 2;
  }
  .feat-title {
    font-size: 1.2rem;
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }
  .more {
    display: block;
    margin-top: 1rem;
    font-size: 0.5rem;
    color: var(--lime);
  }

  .donate {
    background-color: var(--deep-moss);
    border-color: var(--phosphor);
    box-shadow: 5px 5px 0 var(--lime);
    text-align: center;
  }
  .donate-title,
  .topics-title {
    font-size: 0.7rem;
    line-height: 1.5;
    margin: 0 0 0.5rem;
  }

  .topics {
    background-color: var(--deep-moss);
    border-color: var(--phosphor);
    box-shadow: 4px 4px 0 var(--lime);
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }
</style>
