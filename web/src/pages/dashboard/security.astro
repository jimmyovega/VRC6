---
import { env } from "cloudflare:workers";
import { eq } from "drizzle-orm";
import Layout from "../../layouts/Layout.astro";
import { getDb, schema } from "../../db";

// Auth enforced in middleware.
const me = Astro.locals.user!;
const db = getDb(env.DB);
const [row] = await db
  .select({ enabled: schema.user.twoFactorEnabled })
  .from(schema.user)
  .where(eq(schema.user.id, me.id))
  .limit(1);
const enabled = row?.enabled ?? false;
---

<Layout center topShare={1} bottomShare={3} title="Security — VRC6">
  <div class="prose security" data-enabled={String(enabled)}>
    <h1 class="page-title pixel">Security</h1>

    <h2 class="section pixel">TWO-FACTOR AUTHENTICATION</h2>
    <p class="status pixel">
      Status: <strong>{enabled ? "ON" : "OFF"}</strong>
    </p>

    {
      enabled ? (
        <div class="card panel" id="disable-panel">
          <p>Two-factor authentication is protecting your account.</p>
          <label class="field">
            <span class="label pixel">CONFIRM PASSWORD</span>
            <input type="password" id="disable-password" autocomplete="current-password" />
          </label>
          <p class="result pixel" id="disable-result" hidden />
          <button class="btn pixel danger" id="disable-btn">DISABLE 2FA</button>
        </div>
      ) : (
        <div class="card panel" id="enable-panel">
          <p>Add a time-based one-time code (authenticator app) to your logins.</p>

          <div id="step-start">
            <label class="field">
              <span class="label pixel">CONFIRM PASSWORD</span>
              <input type="password" id="enable-password" autocomplete="current-password" />
            </label>
            <p class="result pixel" id="enable-result" hidden />
            <button class="btn pixel" id="enable-btn">ENABLE 2FA</button>
          </div>

          <div id="step-verify" hidden>
            <p class="hint pixel">Scan this with your authenticator app:</p>
            <img id="qr" alt="2FA QR code" width="180" height="180" />
            <details class="manual">
              <summary class="pixel">Can't scan? Enter the key manually</summary>
              <code id="manual-secret" class="secret"></code>
            </details>

            <p class="hint pixel">Save your backup codes — each works once:</p>
            <ul id="backup-codes" class="backup"></ul>

            <label class="field">
              <span class="label pixel">ENTER A CODE TO CONFIRM</span>
              <input type="text" id="confirm-code" inputmode="numeric" autocomplete="one-time-code" />
            </label>
            <p class="result pixel" id="confirm-result" hidden />
            <button class="btn pixel" id="confirm-btn">CONFIRM & TURN ON</button>
          </div>
        </div>
      )
    }

    <p><a class="btn pixel back-link" href="/dashboard">BACK TO DASHBOARD</a></p>
  </div>
</Layout>

<script>
  import QRCode from "qrcode";

  const json = { "Content-Type": "application/json" };
  const post = (path: string, body: unknown) =>
    fetch(path, { method: "POST", headers: json, body: JSON.stringify(body) });
  const show = (el: Element | null, msg: string, err = false) => {
    if (!(el instanceof HTMLElement)) return;
    el.hidden = false;
    el.textContent = msg;
    el.classList.toggle("err", err);
  };

  // --- Enable flow ---
  const enableBtn = document.getElementById("enable-btn");
  enableBtn?.addEventListener("click", async () => {
    const pw = (document.getElementById("enable-password") as HTMLInputElement)?.value ?? "";
    const res = await post("/api/auth/two-factor/enable", { password: pw });
    if (!res.ok) {
      show(document.getElementById("enable-result"), "Incorrect password.", true);
      return;
    }
    const { totpURI, backupCodes } = (await res.json()) as {
      totpURI: string;
      backupCodes: string[];
    };
    const img = document.getElementById("qr") as HTMLImageElement | null;
    if (img) img.src = await QRCode.toDataURL(totpURI);
    const secret = new URL(totpURI).searchParams.get("secret") ?? "";
    const manual = document.getElementById("manual-secret");
    if (manual) manual.textContent = secret;
    const list = document.getElementById("backup-codes");
    if (list) list.innerHTML = backupCodes.map((c) => `<li>${c}</li>`).join("");
    document.getElementById("step-start")?.setAttribute("hidden", "");
    document.getElementById("step-verify")?.removeAttribute("hidden");
  });

  const confirmBtn = document.getElementById("confirm-btn");
  confirmBtn?.addEventListener("click", async () => {
    const code = (document.getElementById("confirm-code") as HTMLInputElement)?.value.trim() ?? "";
    const res = await post("/api/auth/two-factor/verify-totp", { code });
    const ok = res.ok && ((await res.json().catch(() => ({}))) as { status?: boolean }).status !== false;
    if (ok) {
      window.location.reload();
    } else {
      show(document.getElementById("confirm-result"), "Invalid code — try again.", true);
    }
  });

  // --- Disable flow ---
  const disableBtn = document.getElementById("disable-btn");
  disableBtn?.addEventListener("click", async () => {
    const pw = (document.getElementById("disable-password") as HTMLInputElement)?.value ?? "";
    const res = await post("/api/auth/two-factor/disable", { password: pw });
    if (res.ok) window.location.reload();
    else show(document.getElementById("disable-result"), "Incorrect password.", true);
  });
</script>

<style>
  .security {
    max-width: 520px;
    margin-inline: auto;
  }
  .section {
    font-size: 0.7rem;
    color: var(--lime);
    margin: 1.5rem 0 0.5rem;
  }
  .status {
    font-size: 0.6rem;
  }
  .panel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field .label {
    font-size: 0.5rem;
    color: var(--lime);
  }
  .field input {
    background: var(--deep-moss);
    border: 2px solid var(--lime);
    color: var(--phosphor);
    padding: 0.6rem;
    font-family: inherit;
    font-size: 0.95rem;
  }
  .field input:focus {
    outline: none;
    border-color: var(--phosphor);
  }
  #qr {
    image-rendering: pixelated;
    border: 4px solid var(--lime);
    background: #fff;
    display: block;
  }
  .manual summary {
    font-size: 0.5rem;
    color: var(--lime);
    cursor: pointer;
  }
  .secret {
    display: block;
    margin-top: 0.5rem;
    word-break: break-all;
    color: var(--phosphor);
    font-size: 0.85rem;
  }
  .backup {
    columns: 2;
    list-style: none;
    padding: 0.75rem;
    margin: 0;
    border: 2px dashed var(--lime);
    color: var(--phosphor);
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }
  .hint {
    font-size: 0.5rem;
    color: var(--lime);
    margin: 0;
  }
  .result {
    font-size: 0.5rem;
    color: var(--lime);
    margin: 0;
  }
  .result.err {
    color: #fca5a5;
  }
  .btn.danger {
    color: #fca5a5;
    border-color: #fca5a5;
  }
  .back-link {
    display: inline-block;
    text-decoration: none;
    cursor: pointer;
  }
</style>
