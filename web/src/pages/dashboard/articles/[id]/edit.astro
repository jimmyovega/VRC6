---
import { env } from "cloudflare:workers";
import Layout from "../../../../layouts/Layout.astro";
import { getDb } from "../../../../db";
import { getArticleById, getCategoryOptions } from "../../../../db/queries";
import { canEditArticle, canViewArticle } from "../../../../lib/permissions";
import { whyCannotSubmit } from "../../../../lib/article";
import { isDocJson, renderBodyToHtml } from "../../../../lib/body";
import { focusPosition, mediaUrl } from "../../../../lib/media";

const mediaEnv = env as typeof env & { MEDIA_BASE_URL?: string };

// Authenticated (middleware gates /dashboard/*); load + authorize the article.
const user = Astro.locals.user!;
const id = Number(Astro.params.id);
if (!Number.isInteger(id) || id <= 0) return Astro.redirect("/dashboard");

const db = getDb(env.DB);
const article = await getArticleById(db, id);
// Not viewable at all → back to the dashboard.
if (!article || !canViewArticle(user, article)) return Astro.redirect("/dashboard");

// Editors can edit only their own drafts; a submitted/published article opens
// read-only (admins can still edit any state).
const editable = canEditArticle(user, article);
const categories = editable ? await getCategoryOptions(db) : [];
const blocker = editable ? whyCannotSubmit(article) : null;
// An admin viewing an article awaiting review gets approve / reject controls.
const isReviewer = user.role === "admin" && article.status === "pending_review";

// New drafts are stored as a proper TipTap doc; anything else (e.g. a legacy
// M1 body) opens as a blank canvas rather than mis-parsing.
const initialBody = isDocJson(article.body)
  ? article.body
  : { type: "doc", content: [{ type: "paragraph" }] };
const isPlaceholderTitle = article.title === "Untitled draft";
// Escape `<` so the embedded JSON can't break out of the <script> tag.
const bodyJson = JSON.stringify(initialBody).replace(/</g, "\\u003c");
const readonlyHtml = editable ? "" : renderBodyToHtml(article.body);
const coverUrl = article.featuredImageKey ? mediaUrl(article.featuredImageKey, mediaEnv.MEDIA_BASE_URL) : null;
const coverFocusPos = focusPosition(article.featuredImageFocus);
---

<Layout title={`${editable ? "Edit" : "View"} — ${article.title} — VRC6`}>
  <div
    class="editor-page"
    id="editor-app"
    data-article-id={id}
    data-cover-key={article.featuredImageKey ?? ""}
    data-cover-focus={article.featuredImageFocus ?? ""}
  >
    <a class="back" href="/dashboard">&larr; Back to dashboard</a>
    <div class="editor-head">
      <span class={`tagpill st-${article.status}`}>{article.status.replace(/_/g, " ").toUpperCase()}</span>
      {editable && <span class="save-status pixel" id="save-status">Saved ✓</span>}
      {editable && <button class="btn pixel save-now" id="save-now" type="button">SAVE</button>}
    </div>

    {
      article.status === "draft" && article.rejectionReason && (
        <p class="banner reject pixel">✏️ Sent back for changes: {article.rejectionReason}</p>
      )
    }
    {
      !editable && article.status === "pending_review" && (
        <p class="banner pixel">⏳ Submitted for review — read-only until an admin decides.</p>
      )
    }
    {
      !editable && article.status === "published" && (
        <p class="banner pixel">
          ✅ Published — <a href={`/articles/${article.slug}`}>view it live</a>.
        </p>
      )
    }

    {
      isReviewer && (
        <div class="review-bar">
          <span class="review-label pixel">ADMIN REVIEW</span>
          <form method="POST" action={`/api/articles/${id}/approve`} class="rev-form">
            <button class="btn pixel approve-btn" type="submit">APPROVE &amp; PUBLISH</button>
          </form>
          <form method="POST" action={`/api/articles/${id}/reject`} class="rev-form reject-form">
            <input
              class="reason-input"
              type="text"
              name="reason"
              placeholder="Reason to send back"
              required
              maxlength="500"
            />
            <button class="btn pixel reject-btn" type="submit">REJECT</button>
          </form>
        </div>
      )
    }

    {
      editable ? (
        <Fragment>
          <input
            class="art-title"
            id="art-title"
            type="text"
            placeholder="Article title"
            value={isPlaceholderTitle ? "" : article.title}
            maxlength="200"
          />
          <textarea
            class="art-excerpt"
            id="art-excerpt"
            placeholder="Short excerpt (shown on cards)"
            rows="2"
            maxlength="500">{article.excerpt ?? ""}</textarea>

          <div class="cover-field">
            <span class="cover-label pixel">COVER IMAGE</span>
            <div class="cover-preview" id="cover-preview">
              <img
                src={coverUrl ?? ""}
                alt=""
                id="cover-img"
                hidden={!coverUrl}
                draggable="false"
                style={`object-position:${coverFocusPos}`}
              />
              {/* Dashed guide = how the smaller article-card crop lands, so you
                  can frame for both the featured hero and an ordinary card. */}
              <div class="cover-guide" id="cover-guide" hidden={!coverUrl}></div>
              <div class="cover-placeholder pixel" id="cover-placeholder" hidden={!!coverUrl}>
                NO COVER
              </div>
            </div>
            <p class="cover-hint pixel" id="cover-hint" hidden={!coverUrl}>
              Drag the image to reposition · dashed box = small-card crop
            </p>
            <div class="cover-actions">
              <button class="btn pixel" type="button" id="cover-upload-btn">UPLOAD COVER</button>
              <button class="btn pixel cover-remove-btn" type="button" id="cover-remove-btn" hidden={!coverUrl}>
                REMOVE COVER
              </button>
            </div>
          </div>

          <label class="cat-field pixel">
            <span>CATEGORY</span>
            <select id="art-category">
              <option value="">— none —</option>
              {categories.map((c) => (
                <option value={c.id} selected={c.id === article.categoryId}>
                  {c.label}
                </option>
              ))}
            </select>
          </label>

          <div class="toolbar pixel" id="toolbar">
            <button type="button" data-cmd="bold" title="Bold"><b>B</b></button>
            <button type="button" data-cmd="italic" title="Italic"><i>I</i></button>
            <button type="button" data-cmd="strike" title="Strikethrough"><s>S</s></button>
            <button type="button" data-cmd="code" title="Inline code">&lt;/&gt;</button>
            <span class="sep" />
            <button type="button" data-cmd="h2" title="Heading 2">H2</button>
            <button type="button" data-cmd="h3" title="Heading 3">H3</button>
            <span class="sep" />
            <button type="button" data-cmd="bulletList" title="Bullet list">• List</button>
            <button type="button" data-cmd="orderedList" title="Numbered list">1. List</button>
            <button type="button" data-cmd="blockquote" title="Quote">&ldquo; &rdquo;</button>
            <button type="button" data-cmd="codeBlock" title="Code block">Code</button>
            <span class="sep" />
            <button type="button" data-cmd="link" title="Link">Link</button>
            <button type="button" data-cmd="image" title="Image URL">Image</button>
            <button type="button" data-cmd="hr" title="Divider">HR</button>
            <span class="sep" />
            <button type="button" data-cmd="alignLeft" title="Align left">L</button>
            <button type="button" data-cmd="alignCenter" title="Align center">C</button>
            <button type="button" data-cmd="alignRight" title="Align right">R</button>
          </div>

          <div class="editor-surface" id="editor" />

          <div class="submit-row">
            {article.status === "draft" && (
              <form method="POST" action={`/api/articles/${id}/submit`} id="submit-form">
                <button class="btn pixel submit-btn" type="submit" disabled={blocker !== null}>
                  SUBMIT FOR REVIEW
                </button>
              </form>
            )}
            {article.status === "published" && (
              <form method="POST" action={`/api/articles/${id}/unpublish`}>
                <button class="btn pixel unpublish-btn" type="submit">UNPUBLISH</button>
              </form>
            )}
            <form method="POST" action={`/api/articles/${id}/delete`} class="delete-form">
              <button class="btn pixel delete-btn" type="submit">DELETE</button>
            </form>
            {article.status === "draft" && (
              <span class="submit-hint pixel" id="submit-hint">{blocker ?? ""}</span>
            )}
          </div>

          <script type="application/json" id="article-body" set:html={bodyJson} />
        </Fragment>
      ) : (
        <article class="prose readonly">
          <h1 class="page-title pixel">{article.title}</h1>
          <div class="body" set:html={readonlyHtml} />
        </article>
      )
    }
  </div>
</Layout>

<script>
  import { Editor } from "@tiptap/core";
  import StarterKit from "@tiptap/starter-kit";
  import BaseImage from "@tiptap/extension-image";
  import TextAlign from "@tiptap/extension-text-align";

  // Server renderer (lib/body.ts) only understands these three; "justify" is
  // deliberately excluded from the extension's allowlist below.
  const ALIGNMENTS = ["left", "center", "right"] as const;

  // Add an `align` attribute to the built-in Image node (rendered as
  // data-align, matching the pattern used for the cover's focal point style).
  const Image = BaseImage.extend({
    addAttributes() {
      return {
        ...this.parent?.(),
        align: {
          default: null,
          parseHTML: (el: HTMLElement) => el.getAttribute("data-align"),
          renderHTML: (attrs: { align?: string | null }) =>
            attrs.align ? { "data-align": attrs.align } : {},
        },
      };
    },
  });

  const app = document.getElementById("editor-app");
  const mount = document.getElementById("editor");
  if (app && mount) {
    const articleId = app.dataset.articleId;
    const titleInput = document.getElementById("art-title") as HTMLInputElement | null;
    const excerptInput = document.getElementById("art-excerpt") as HTMLTextAreaElement | null;
    const status = document.getElementById("save-status");
    const toolbar = document.getElementById("toolbar");
    const saveNow = document.getElementById("save-now");
    const catSelect = document.getElementById("art-category") as HTMLSelectElement | null;
    const coverImg = document.getElementById("cover-img") as HTMLImageElement | null;
    const coverPreview = document.getElementById("cover-preview");
    const coverPlaceholder = document.getElementById("cover-placeholder");
    const coverGuide = document.getElementById("cover-guide");
    const coverHint = document.getElementById("cover-hint");
    const coverUploadBtn = document.getElementById("cover-upload-btn");
    const coverRemoveBtn = document.getElementById("cover-remove-btn") as HTMLButtonElement | null;
    let coverImageKey: string | null = app.dataset.coverKey || null;
    // Focal point as [x%, y%]; parsed from the saved "X% Y%" or centered.
    const parseFocusPair = (s: string | undefined): [number, number] => {
      const m = (s || "").match(/-?\d+(?:\.\d+)?/g);
      if (!m || m.length < 2) return [50, 50];
      const clamp = (n: number) => Math.max(0, Math.min(100, n));
      return [clamp(Number(m[0])), clamp(Number(m[1]))];
    };
    let coverFocus = parseFocusPair(app.dataset.coverFocus);
    const submitForm = document.getElementById("submit-form") as HTMLFormElement | null;
    const submitBtn = submitForm?.querySelector("button") as HTMLButtonElement | null;
    const submitHint = document.getElementById("submit-hint");

    const EMPTY = { type: "doc", content: [{ type: "paragraph" }] };
    let initial: unknown = EMPTY;
    try {
      initial = JSON.parse(document.getElementById("article-body")?.textContent || "");
    } catch {
      initial = EMPTY;
    }

    const editor = new Editor({
      element: mount,
      extensions: [
        StarterKit.configure({
          // Underline has no counterpart in the server renderer, so keep it out.
          underline: false,
          heading: { levels: [2, 3] },
          link: {
            openOnClick: false,
            autolink: true,
            HTMLAttributes: { rel: "noopener noreferrer nofollow" },
          },
        }),
        Image,
        TextAlign.configure({
          types: ["paragraph", "heading"],
          alignments: [...ALIGNMENTS],
          defaultAlignment: null,
        }),
      ],
      content: initial,
      onUpdate: () => {
        scheduleSave();
        refreshToolbar();
        refreshSubmit();
      },
      onSelectionUpdate: refreshToolbar,
    });

    const MARK_OR_NODE = [
      "bold",
      "italic",
      "strike",
      "code",
      "bulletList",
      "orderedList",
      "blockquote",
      "codeBlock",
      "link",
    ];
    const ALIGN_CMDS: Record<string, (typeof ALIGNMENTS)[number]> = {
      alignLeft: "left",
      alignCenter: "center",
      alignRight: "right",
    };
    function refreshToolbar() {
      toolbar?.querySelectorAll<HTMLElement>("[data-cmd]").forEach((btn) => {
        const cmd = btn.dataset.cmd!;
        let active = false;
        if (cmd === "h2") active = editor.isActive("heading", { level: 2 });
        else if (cmd === "h3") active = editor.isActive("heading", { level: 3 });
        else if (cmd in ALIGN_CMDS) {
          const a = ALIGN_CMDS[cmd];
          active = editor.isActive({ textAlign: a }) || editor.isActive("image", { align: a });
        } else if (MARK_OR_NODE.includes(cmd)) active = editor.isActive(cmd);
        btn.classList.toggle("is-active", active);
      });
    }

    // Prevent the browser's native click-focuses-the-button behavior, which
    // would steal DOM focus from the editor right after our handler's
    // chain.focus() restores it — otherwise a keystroke immediately following
    // a toolbar click (e.g. pressing Enter right after aligning a paragraph,
    // to keep writing) lands on the button instead of the editor.
    toolbar?.addEventListener("mousedown", (e) => {
      if ((e.target as HTMLElement).closest("[data-cmd]")) e.preventDefault();
    });

    toolbar?.querySelectorAll<HTMLElement>("[data-cmd]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const cmd = btn.dataset.cmd;
        const chain = editor.chain().focus();
        switch (cmd) {
          case "bold": chain.toggleBold().run(); break;
          case "italic": chain.toggleItalic().run(); break;
          case "strike": chain.toggleStrike().run(); break;
          case "code": chain.toggleCode().run(); break;
          case "h2": chain.toggleHeading({ level: 2 }).run(); break;
          case "h3": chain.toggleHeading({ level: 3 }).run(); break;
          case "bulletList": chain.toggleBulletList().run(); break;
          case "orderedList": chain.toggleOrderedList().run(); break;
          case "blockquote": chain.toggleBlockquote().run(); break;
          case "codeBlock": chain.toggleCodeBlock().run(); break;
          case "hr": chain.setHorizontalRule().run(); break;
          case "alignLeft":
          case "alignCenter":
          case "alignRight": {
            const alignment = ALIGN_CMDS[cmd];
            if (editor.isActive("image")) {
              // Toggle off (back to the default/left) on a second click, same
              // feel as the text-align toggle command below.
              const current = editor.getAttributes("image").align;
              chain.updateAttributes("image", { align: current === alignment ? null : alignment }).run();
            } else {
              chain.toggleTextAlign(alignment).run();
            }
            break;
          }
          case "link": {
            const prev = (editor.getAttributes("link").href as string) ?? "";
            const url = window.prompt("Link URL", prev);
            if (url === null) { chain.run(); break; }
            if (url === "") { chain.extendMarkRange("link").unsetLink().run(); break; }
            chain.extendMarkRange("link").setLink({ href: url }).run();
            break;
          }
          case "image": {
            pickAndUploadImage();
            break;
          }
          default: chain.run();
        }
        refreshToolbar();
      });
    });

    // ---- Debounced autosave ----
    let timer: ReturnType<typeof setTimeout> | undefined;
    let dirty = false;
    let saving = false;
    const setStatus = (t: string) => { if (status) status.textContent = t; };

    function scheduleSave() {
      dirty = true;
      setStatus("Unsaved changes…");
      clearTimeout(timer);
      timer = setTimeout(save, 1200);
    }

    async function save() {
      if (saving) return;
      saving = true;
      dirty = false;
      setStatus("Saving…");
      try {
        const res = await fetch(`/api/articles/${articleId}`, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            title: titleInput?.value ?? "",
            excerpt: excerptInput?.value ?? "",
            body: editor.getJSON(),
            categoryId: catSelect?.value ? Number(catSelect.value) : null,
            featuredImageKey: coverImageKey,
            featuredImageFocus: coverImageKey ? `${coverFocus[0]}% ${coverFocus[1]}%` : null,
          }),
        });
        setStatus(res.ok ? "Saved ✓" : "Save failed — retrying…");
        if (!res.ok) dirty = true;
      } catch {
        setStatus("Save failed (offline?)");
        dirty = true;
      } finally {
        saving = false;
        if (dirty) scheduleSave();
      }
    }

    // Open a file picker restricted to images; resolves to the chosen file
    // (or null if the user cancelled).
    function pickImageFile(): Promise<File | null> {
      return new Promise((resolve) => {
        const input = document.createElement("input");
        input.type = "file";
        input.accept = "image/png,image/jpeg,image/webp,image/gif";
        input.addEventListener("change", () => resolve(input.files?.[0] ?? null));
        input.click();
      });
    }

    // Upload a picked file to R2 via the shared endpoint (used for both
    // inline body images and the cover image below).
    async function uploadImage(file: File): Promise<{ url: string; key: string } | null> {
      try {
        const fd = new FormData();
        fd.append("file", file);
        const res = await fetch("/api/uploads", { method: "POST", body: fd });
        if (res.ok) return (await res.json()) as { url: string; key: string };
        const j = (await res.json().catch(() => ({}))) as { error?: string };
        setStatus(j.error ?? "Image upload failed");
      } catch {
        setStatus("Image upload failed");
      }
      return null;
    }

    async function pickAndUploadImage() {
      const file = await pickImageFile();
      if (!file) return;
      setStatus("Uploading image…");
      const result = await uploadImage(file);
      // setImage fires onUpdate → the new body (with the image) autosaves.
      if (result) editor.chain().focus().setImage({ src: result.url }).run();
    }

    // Representative desktop aspect ratios (width ÷ height): the preview frame
    // is the hero's crop shape; a small (non-hero) card is wider + shorter.
    const HERO_AR = 11 / 5; // 2.2 — keep in sync with .cover-preview aspect-ratio
    const CARD_AR = 3.7; // ~608 / 165 at desktop

    // Place the small-card guide band. Because object-fit:cover crops a
    // different-shaped box to a different vertical slice for the same focal
    // point, the card doesn't share the hero's crop — this draws where the card
    // actually lands *within* the hero crop the preview shows. Derivation:
    // band height = HERO_AR/CARD_AR of the preview; band centre offset from the
    // preview centre = (HERO_AR/CARD_AR − 1)·(0.5 − focusY). (Image-independent.)
    function positionGuide() {
      if (!coverPreview || !coverGuide || coverImg?.hidden) return;
      const h = coverPreview.clientHeight;
      if (!h) return;
      const p = coverFocus[1] / 100; // focal Y as a fraction
      const k = HERO_AR / CARD_AR;
      const heightFrac = Math.min(1, k);
      const centerFrac = 0.5 + (k - 1) * (0.5 - p);
      const topFrac = Math.max(0, Math.min(1 - heightFrac, centerFrac - heightFrac / 2));
      coverGuide.style.top = `${topFrac * h}px`;
      coverGuide.style.height = `${heightFrac * h}px`;
    }

    // Push the current focal point to the preview image + guide.
    function applyFocus() {
      if (coverImg) coverImg.style.objectPosition = `${coverFocus[0]}% ${coverFocus[1]}%`;
      positionGuide();
    }

    function setCoverPreview(url: string | null) {
      if (coverImg) {
        coverImg.src = url ?? "";
        coverImg.hidden = !url;
      }
      if (coverPlaceholder) coverPlaceholder.hidden = !!url;
      if (coverGuide) coverGuide.hidden = !url;
      if (coverHint) coverHint.hidden = !url;
      if (coverRemoveBtn) coverRemoveBtn.hidden = !url;
      applyFocus();
    }

    // ---- Drag-to-pan: translate cursor movement into an object-position focal
    // point. Moving the image down reveals its top (focus Y → 0), etc. ----
    let panning = false;
    let panStartX = 0;
    let panStartY = 0;
    let panFocusStart: [number, number] = [50, 50];
    coverPreview?.addEventListener("pointerdown", (e) => {
      if (coverImg?.hidden) return;
      panning = true;
      panStartX = e.clientX;
      panStartY = e.clientY;
      panFocusStart = [coverFocus[0], coverFocus[1]];
      coverPreview.setPointerCapture(e.pointerId);
    });
    coverPreview?.addEventListener("pointermove", (e) => {
      if (!panning || !coverPreview) return;
      const w = coverPreview.clientWidth || 1;
      const h = coverPreview.clientHeight || 1;
      const clamp = (n: number) => Math.max(0, Math.min(100, n));
      coverFocus = [
        Math.round(clamp(panFocusStart[0] - ((e.clientX - panStartX) / w) * 100)),
        Math.round(clamp(panFocusStart[1] - ((e.clientY - panStartY) / h) * 100)),
      ];
      applyFocus();
    });
    const endPan = () => {
      if (!panning) return;
      panning = false;
      scheduleSave();
    };
    coverPreview?.addEventListener("pointerup", endPan);
    coverPreview?.addEventListener("pointercancel", endPan);
    window.addEventListener("resize", positionGuide);

    coverUploadBtn?.addEventListener("click", async () => {
      const file = await pickImageFile();
      if (!file) return;
      setStatus("Uploading cover…");
      const result = await uploadImage(file);
      if (result) {
        coverImageKey = result.key;
        coverFocus = [50, 50]; // a fresh image starts centered
        setCoverPreview(result.url);
        scheduleSave();
      }
    });

    coverRemoveBtn?.addEventListener("click", () => {
      coverImageKey = null;
      coverFocus = [50, 50];
      setCoverPreview(null);
      scheduleSave();
    });

    // Position the guide for an already-saved cover on load (once the image box
    // has its dimensions).
    applyFocus();
    if (coverImg && !coverImg.hidden) {
      if (coverImg.complete) positionGuide();
      coverImg.addEventListener("load", positionGuide);
    }

    // ---- Submit-for-review readiness (mirrors the server's whyCannotSubmit) ----
    function submitBlocker(): string | null {
      const t = (titleInput?.value ?? "").trim();
      if (!t || t === "Untitled draft") return "Give your article a title before submitting.";
      if (!editor.getText().trim()) return "Write some content before submitting.";
      if (!catSelect?.value) return "Choose a category before submitting.";
      return null;
    }
    function refreshSubmit() {
      const b = submitBlocker();
      if (submitBtn) submitBtn.disabled = b !== null;
      if (submitHint) submitHint.textContent = b ?? "";
    }

    titleInput?.addEventListener("input", () => { scheduleSave(); refreshSubmit(); });
    excerptInput?.addEventListener("input", scheduleSave);
    catSelect?.addEventListener("change", () => { scheduleSave(); refreshSubmit(); });
    saveNow?.addEventListener("click", () => { clearTimeout(timer); save(); });
    // Flush the latest edits, then hand off to the server to change status.
    submitForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (submitBlocker()) { refreshSubmit(); return; }
      clearTimeout(timer);
      await save();
      submitForm.submit(); // form.submit() doesn't refire this handler
    });
    // Confirm destructive delete (soft-delete, but still a surprise if misclicked).
    document.querySelector(".delete-form")?.addEventListener("submit", (e) => {
      if (!confirm("Delete this article?")) e.preventDefault();
    });
    // Flush pending edits when the tab is hidden (navigation / close).
    document.addEventListener("visibilitychange", () => {
      if (document.visibilityState === "hidden" && dirty) save();
    });

    refreshToolbar();
    refreshSubmit();
  }
</script>

<style>
  .editor-page {
    max-width: 820px;
    margin-inline: auto;
    width: 100%;
  }
  .back {
    display: inline-block;
    font-size: 0.5rem;
    color: var(--lime);
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .editor-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .tagpill {
    font-size: 0.4rem;
    padding: 0.3rem 0.45rem;
    background: var(--deep-moss);
    color: var(--phosphor);
    border: 1px solid var(--lime);
  }
  .save-status {
    font-size: 0.5rem;
    color: var(--lime);
    margin-left: auto;
  }
  .save-now {
    cursor: pointer;
  }
  .art-title {
    width: 100%;
    background: var(--deep-moss);
    border: 2px solid var(--lime);
    color: var(--phosphor);
    font-size: 1.4rem;
    font-family: "Press Start 2P", monospace;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .art-excerpt {
    width: 100%;
    background: var(--deep-moss);
