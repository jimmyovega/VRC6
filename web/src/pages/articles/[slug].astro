---
// Article detail page. Renders only published articles; anything else → themed 404.
// Desktop: article text (left, scrolls) + sticky rail (right) with cover image,
// reading progress, info panel, related reads, and share/support.
// Mobile: cover image above the article, the rest of the rail below it.
import { env } from "cloudflare:workers";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Layout from "../../layouts/Layout.astro";
import { getDb } from "../../db";
import { getArticlesByCategory, getPublishedArticleBySlug } from "../../db/queries";
import { readingTimeMinutes, renderBodyToHtml } from "../../lib/body";
import { formatDate } from "../../lib/date";
import { focusPosition, mediaUrl } from "../../lib/media";

const mediaEnv = env as typeof env & { MEDIA_BASE_URL?: string };
const { slug } = Astro.params;
const db = getDb(env.DB);
const article = slug ? await getPublishedArticleBySlug(db, slug) : null;

if (!article) {
  return Astro.rewrite("/404");
}

const coverUrl = article.featuredImageKey
  ? mediaUrl(article.featuredImageKey, mediaEnv.MEDIA_BASE_URL)
  : null;
const coverFocus = focusPosition(article.featuredImageFocus);
const bodyHtml = renderBodyToHtml(article.body);
const byline = article.author ?? article.authorUsername ?? "VRC6";
const dateLabel = formatDate(article.publishedAt);
const minutes = readingTimeMinutes(article.body, article.excerpt);

const related = article.categorySlug
  ? (await getArticlesByCategory(db, article.categorySlug))
      .filter((a) => a.slug !== article.slug)
      .slice(0, 3)
  : [];

const infoRows: { k: string; v: string }[] = [];
if (article.category) infoRows.push({ k: "Topic", v: article.category });
if (dateLabel) infoRows.push({ k: "Published", v: dateLabel });
infoRows.push({ k: "Read", v: `${minutes} min` });
infoRows.push({ k: "By", v: byline });

const shareUrl = Astro.url.href;
const xUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(shareUrl)}`;
const bskyUrl = `https://bsky.app/intent/compose?text=${encodeURIComponent(`${article.title} ${shareUrl}`)}`;
---

<Layout
  center
  topShare={1}
  bottomShare={3}
  title={`${article.title} — VRC6`}
  description={article.excerpt ?? undefined}
>
  <div class="article-layout">
    <article class="prose">
      <Breadcrumb
        items={[
          { label: "Home", href: "/" },
          ...(article.categorySlug
            ? [
                {
                  label: article.category ?? "Category",
                  href: `/category/${article.categorySlug}`,
                },
              ]
            : []),
        ]}
      />
      <h1 class="page-title pixel">{article.title}</h1>
      <p class="byline pixel">By {byline}{dateLabel && ` · ${dateLabel}`}</p>
      {article.excerpt && <p class="lead">{article.excerpt}</p>}
      <div class="body" set:html={bodyHtml} />
    </article>

    <aside class="rail">
      {
        coverUrl && (
          <div class="cover">
            <img class="cover-img" src={coverUrl} alt="" style={`object-position:${coverFocus}`} />
          </div>
        )
      }

      <div class="extras">
        <div class="panel">
          <span class="panel-label pixel">READING</span>
          <div class="bar"><div class="bar-fill"></div></div>
        </div>

        <div class="panel">
          <span class="panel-label pixel">INFO</span>
          <dl class="info-list">
            {
              infoRows.map((row) => (
                <div class="info-row">
                  <dt>{row.k}</dt>
                  <dd>{row.v}</dd>
                </div>
              ))
            }
          </dl>
        </div>

        {
          related.length > 0 && (
            <div class="panel">
              <span class="panel-label pixel">
                MORE IN {(article.category ?? "VRC6").toUpperCase()}
              </span>
              <ul class="related-list">
                {related.map((r) => (
                  <li>
                    <a href={`/articles/${r.slug}`}>{r.title}</a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        <div class="panel">
          <span class="panel-label pixel">SHARE</span>
          <div class="share-row">
            <button class="chip pixel" type="button" data-copy aria-label="Copy link">COPY</button>
            <a class="chip pixel" href={xUrl} target="_blank" rel="noopener noreferrer">X</a>
            <a class="chip pixel" href={bskyUrl} target="_blank" rel="noopener noreferrer">BSKY</a>
          </div>
          <a
            class="btn pixel support-btn"
            href="https://ko-fi.com/vrcsix"
            target="_blank"
            rel="noopener noreferrer"
          >
            SUPPORT VRC6
          </a>
        </div>
      </div>
    </aside>
  </div>
</Layout>

<script>
  import { initCarousels } from "../../lib/carousel-client";
  // Wire up any carousels in the article body (paging + gallery lightbox).
  initCarousels(document);

  const fill = document.querySelector<HTMLElement>(".bar-fill");
  const article = document.querySelector<HTMLElement>(".prose");
  if (fill && article) {
    const update = () => {
      const rect = article.getBoundingClientRect();
      const denom = rect.height - window.innerHeight;
      const pct = denom <= 0 ? 100 : (Math.min(Math.max(-rect.top, 0), denom) / denom) * 100;
      fill.style.width = `${Math.round(pct)}%`;
    };
    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update);
    update();
  }

  const copyBtn = document.querySelector<HTMLButtonElement>("[data-copy]");
  copyBtn?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      const original = copyBtn.textContent;
      copyBtn.textContent = "COPIED";
      setTimeout(() => {
        copyBtn.textContent = original;
      }, 1500);
    } catch {
      // clipboard unavailable — ignore
    }
  });
</script>

<style>
  .article-layout {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .rail {
    display: contents;
  }
  .cover {
    order: -1;
  }
  .extras {
    order: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .byline {
    font-size: 0.5rem;
    color: var(--lime);
    margin: 0 0 1.5rem;
  }
  .lead {
    font-size: 1.05rem;
    color: var(--phosphor);
    font-style: italic;
    margin-bottom: 1.5rem;
  }
  /* Body content is raw HTML from renderBodyToHtml (see lib/body.ts) — style
     it via :global() since Astro doesn't scope injected markup. Images must
     be capped to the prose column (they carry their natural pixel size) and
     get the same green border as the editor's ProseMirror surface. */
  .body :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    border: 2px solid var(--lime);
    margin: 1.25rem 0;
  }
  /* Alignment (renderer emits data-align on the img / text-align inline style
     on paragraphs+headings — see lib/body.ts). Only visible on an image
     narrower than the column; a full-width image has no room to shift. */
  .body :global(img[data-align="center"]) {
    margin-left: auto;
    margin-right: auto;
  }
  .body :global(img[data-align="right"]) {
    margin-left: auto;
    margin-right: 0;
  }
  /* Image list: a small thumbnail "bullet" beside a rich-text excerpt (renderer
     emits <ul class="image-list"><li class="ili">…). Shared class names with the
     editor surface so the draft and the published page match. */
  .body :global(.image-list) {
    list-style: none;
    margin: 1.5rem 0;
    padding: 0;
  }
  .body :global(.ili) {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 0.75rem 0;
    border-top: 1px solid rgba(74, 222, 128, 0.3);
  }
  .body :global(.ili:first-child) {
    border-top: none;
  }
  .body :global(.ili-thumb) {
    flex: 0 0 auto;
    width: 168px;
    height: 168px;
    object-fit: cover;
    /* Override the generic .body img rule (block + 1.25rem vertical margins). */
    margin: 0;
    border: 2px solid var(--lime);
    max-width: none;
  }
  .body :global(.ili-text) {
    flex: 1 1 auto;
    min-width: 0;
    line-height: 1.8;
    color: var(--phosphor);
  }
  /* Carousel: a one-at-a-time slideshow. The viewport carries an inline
     aspect-ratio (sized to the shortest landscape image — see lib/carousel);
     every slide `object-fit: contain`s within it. Click a slide → lightbox. */
  .body :global(.carousel) {
    position: relative;
    margin: 1.5rem 0;
  }
  .body :global(.carousel-viewport) {
    position: relative;
    width: 100%;
    overflow: hidden;
    border: 2px solid var(--lime);
    background: var(--ink);
  }
  .body :global(.carousel-track) {
    display: flex;
    height: 100%;
    transition: transform 0.3s ease;
  }
  .body :global(.carousel-slide) {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: zoom-in;
  }
  /* Override the generic .body img rule (border + block margins) for slides. */
  .body :global(.carousel-slide img) {
    width: 100%;
    height: 100%;
    max-width: 100%;
    object-fit: contain;
    margin: 0;
    border: 0;
    box-shadow: none;
    display: block;
  }
  .body :global(.carousel-arrow) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 2.2rem;
    height: 2.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Press Start 2P", monospace;
    font-size: 1.1rem;
    color: var(--deep-moss);
    background: var(--lime);
    border: 2px solid var(--phosphor);
    cursor: pointer;
  }
  .body :global(.carousel-arrow.prev) {
    left: 0.5rem;
  }
  .body :global(.carousel-arrow.next) {
    right: 0.5rem;
  }
  .body :global(.carousel-dots) {
    display: flex;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }
  .body :global(.carousel-dot) {
    width: 0.7rem;
    height: 0.7rem;
    padding: 0;
    border: 2px solid var(--lime);
    background: transparent;
    cursor: pointer;
  }
  .body :global(.carousel-dot.is-active) {
    background: var(--lime);
  }

  .cover-img {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 2px solid var(--lime);
    box-shadow: 4px 4px 0 var(--phosphor);
  }

  .panel {
    border: 2px solid var(--lime);
    background: var(--forest);
    border-radius: 8px;
    padding: 0.85rem 1rem;
  }
  .panel-label {
    display: block;
    font-size: 0.5rem;
    color: var(--lime);
    margin: 0 0 0.7rem;
  }

  .bar {
    height: 14px;
    background: var(--deep-moss);
    border: 2px solid var(--lime);
  }
  .bar-fill {
    height: 100%;
    width: 0;
    background: var(--lime);
  }

  .info-list {
    margin: 0;
  }
  .info-row {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.8rem;
    padding: 0.25rem 0;
  }
  .info-row dt {
    color: var(--lime);
    margin: 0;
  }
  .info-row dd {
    color: var(--phosphor);
    margin: 0;
    text-align: right;
  }

  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .related-list a {
    display: block;
    color: var(--phosphor);
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.4;
    padding: 0.45rem 0;
    border-top: 1px solid rgba(74, 222, 128, 0.25);
  }
  .related-list li:first-child a {
    border-top: none;
  }
  .related-list a:hover {
    color: var(--lime);
  }

  .share-row {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .share-row .chip {
    border: 0;
    cursor: pointer;
    font-size: 0.5rem;
  }
  .support-btn {
    display: block;
    text-align: center;
    margin-top: 0.8rem;
  }

  /* Desktop: text column + sticky rail (cover + extras together). */
  @media (min-width: 900px) {
    .article-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: 2.5rem;
      align-items: start;
      max-width: 1040px;
      /* `<Layout center>` makes .site-main a column flex container, and this
         element's auto inline margins (for centering) pre-empt flexbox's
         default cross-axis stretch — without an explicit width it falls back
         to shrink-to-fit, sizing to its widest content (title/byline/etc.)
         instead of the intended fixed column. `width: 100%` restores the
         stretch-then-center behavior so every article gets the same width. */
      width: 100%;
      margin-inline: auto;
    }
    .article-layout .prose {
      max-width: none;
    }
    .rail {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: sticky;
      top: 1.5rem;
    }
  }
</style>
