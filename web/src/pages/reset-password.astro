---
import Layout from "../layouts/Layout.astro";

const token = Astro.url.searchParams.get("token") ?? "";
---

<Layout center title="Reset password — VRC6" description="Set a new VRC6 password.">
  <div class="login">
    <h1 class="page-title pixel">Set a new password</h1>
    {
      token ? (
        <form id="reset-form" class="card login-card" data-token={token}>
          <label class="field">
            <span class="label pixel">NEW PASSWORD</span>
            <input
              type="password"
              name="password"
              required
              minlength="12"
              autocomplete="new-password"
            />
          </label>
          <p class="error pixel" id="reset-error" hidden>
            Could not reset — the link may have expired.
          </p>
          <button class="btn pixel submit" type="submit">
            SET PASSWORD
          </button>
        </form>
      ) : (
        <p class="hint pixel">Missing or invalid reset link.</p>
      )
    }
  </div>
</Layout>

<script>
  const form = document.getElementById("reset-form") as HTMLFormElement | null;
  const err = document.getElementById("reset-error");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (err) err.hidden = true;
    const token = form.getAttribute("data-token");
    const password = new FormData(form).get("password");
    const res = await fetch("/api/auth/reset-password", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ newPassword: password, token }),
    });
    if (res.ok) {
      window.location.href = "/login";
    } else if (err) {
      err.hidden = false;
    }
  });
</script>

<style>
  .login {
    max-width: 380px;
    margin-inline: auto;
    width: 100%;
  }
  .login-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field .label {
    font-size: 0.5rem;
    color: var(--lime);
  }
  .field input {
    background: var(--deep-moss);
    border: 2px solid var(--lime);
    color: var(--phosphor);
    padding: 0.6rem;
    font-family: inherit;
    font-size: 0.95rem;
  }
  .field input:focus {
    outline: none;
    border-color: var(--phosphor);
  }
  .hint {
    color: var(--lime);
    font-size: 0.5rem;
  }
  .error {
    color: #fca5a5;
    font-size: 0.5rem;
    margin: 0;
  }
  .submit {
    text-align: center;
    cursor: pointer;
  }
</style>
