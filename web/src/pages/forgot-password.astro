---
import Layout from "../layouts/Layout.astro";
import { getTurnstileSiteKey } from "../lib/turnstile";

if (Astro.locals.user) {
  return Astro.redirect("/");
}
const siteKey = getTurnstileSiteKey();
---

<Layout center title="Forgot password — VRC6" description="Reset your VRC6 password.">
  <div class="login">
    <h1 class="page-title pixel">Forgot password</h1>
    <form id="forgot-form" class="card login-card">
      <label class="field">
        <span class="label pixel">EMAIL</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <p class="hint pixel" id="forgot-sent" hidden>
        If that email exists, a reset link is on its way.
      </p>
      <div class="cf-turnstile" data-sitekey={siteKey} data-theme="dark"></div>
      <button class="btn pixel submit" type="submit">SEND RESET LINK</button>
    </form>
  </div>
</Layout>

<script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>

<script>
  const form = document.getElementById("forgot-form") as HTMLFormElement | null;
  const sent = document.getElementById("forgot-sent");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    await fetch("/api/auth/request-password-reset", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-turnstile-token": String(data.get("cf-turnstile-response") ?? ""),
      },
      body: JSON.stringify({ email: data.get("email"), redirectTo: "/reset-password" }),
    });
    // Always show success — no account enumeration.
    if (sent) sent.hidden = false;
    const btn = form.querySelector("button");
    if (btn) btn.disabled = true;
  });
</script>

<style>
  .login {
    max-width: 380px;
    margin-inline: auto;
    width: 100%;
  }
  .login-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field .label {
    font-size: 0.5rem;
    color: var(--lime);
  }
  .field input {
    background: var(--deep-moss);
    border: 2px solid var(--lime);
    color: var(--phosphor);
    padding: 0.6rem;
    font-family: inherit;
    font-size: 0.95rem;
  }
  .field input:focus {
    outline: none;
    border-color: var(--phosphor);
  }
  .hint {
    color: var(--lime);
    font-size: 0.5rem;
    line-height: 1.6;
    margin: 0;
  }
  .submit {
    text-align: center;
    cursor: pointer;
  }
</style>
