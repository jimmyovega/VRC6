---
import Layout from "../layouts/Layout.astro";
import { getTurnstileSiteKey } from "../lib/turnstile";

// Already signed in → home.
if (Astro.locals.user) {
  return Astro.redirect("/");
}
const siteKey = getTurnstileSiteKey();
---

<Layout center title="Log in — VRC6" description="Sign in to VRC6.">
  <div class="login">
    <h1 class="page-title pixel">Log in</h1>
    <form id="login-form" class="card login-card">
      <label class="field">
        <span class="label pixel">EMAIL</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label class="field">
        <span class="label pixel">PASSWORD</span>
        <input type="password" name="password" required autocomplete="current-password" />
      </label>
      <p class="error pixel" id="login-error" hidden>Invalid email or password.</p>
      <div class="cf-turnstile" data-sitekey={siteKey} data-theme="dark"></div>
      <button class="btn pixel submit" type="submit">SIGN IN</button>
      <a class="forgot-link pixel" href="/forgot-password">Forgot password?</a>
    </form>
  </div>
</Layout>

<script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>

<script>
  const form = document.getElementById("login-form") as HTMLFormElement | null;
  const err = document.getElementById("login-error");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (err) err.hidden = true;
    const data = new FormData(form);
    const res = await fetch("/api/auth/sign-in/email", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-turnstile-token": String(data.get("cf-turnstile-response") ?? ""),
      },
      body: JSON.stringify({
        email: data.get("email"),
        password: data.get("password"),
      }),
    });
    if (res.ok) {
      window.location.href = "/";
    } else if (err) {
      err.hidden = false;
    }
  });
</script>

<style>
  .login {
    max-width: 380px;
    margin-inline: auto;
    width: 100%;
  }
  .login-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field .label {
    font-size: 0.5rem;
    color: var(--lime);
  }
  .field input {
    background: var(--deep-moss);
    border: 2px solid var(--lime);
    color: var(--phosphor);
    padding: 0.6rem;
    font-family: inherit;
    font-size: 0.95rem;
  }
  .field input:focus {
    outline: none;
    border-color: var(--phosphor);
  }
  .error {
    color: #fca5a5;
    font-size: 0.5rem;
    margin: 0;
  }
  .submit {
    text-align: center;
    cursor: pointer;
    margin-top: 0.25rem;
  }
  .forgot-link {
    font-size: 0.5rem;
    color: var(--lime);
    text-align: center;
  }
</style>
