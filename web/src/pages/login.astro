---
import Layout from "../layouts/Layout.astro";
import { getTurnstileSiteKey } from "../lib/turnstile";

// Already signed in → home.
if (Astro.locals.user) {
  return Astro.redirect("/");
}
const siteKey = getTurnstileSiteKey();
---

<Layout center title="Log in — VRC6" description="Sign in to VRC6.">
  <div class="login">
    <h1 class="page-title pixel">Log in</h1>
    <form id="login-form" class="card login-card">
      <label class="field">
        <span class="label pixel">EMAIL</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <label class="field">
        <span class="label pixel">PASSWORD</span>
        <input type="password" name="password" required autocomplete="current-password" />
      </label>
      <p class="error pixel" id="login-error" hidden>Invalid email or password.</p>
      <div class="cf-turnstile" data-sitekey={siteKey} data-theme="dark"></div>
      <button class="btn pixel submit" type="submit">SIGN IN</button>
      <a class="forgot-link pixel" href="/forgot-password">Forgot password?</a>
    </form>

    <form id="twofa-form" class="card login-card" hidden>
      <p class="hint pixel">Enter the 6-digit code from your authenticator app.</p>
      <label class="field">
        <span class="label pixel">CODE</span>
        <input type="text" name="code" inputmode="numeric" autocomplete="one-time-code" />
      </label>
      <p class="error pixel" id="twofa-error" hidden>Invalid code.</p>
      <button class="btn pixel submit" type="submit">VERIFY</button>
    </form>
  </div>
</Layout>

<script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>

<script>
  const form = document.getElementById("login-form") as HTMLFormElement | null;
  const err = document.getElementById("login-error");
  const showError = (msg: string) => {
    if (!err) return;
    err.textContent = msg;
    err.hidden = false;
  };
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (err) err.hidden = true;
    const data = new FormData(form);
    const res = await fetch("/api/auth/sign-in/email", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-turnstile-token": String(data.get("cf-turnstile-response") ?? ""),
      },
      body: JSON.stringify({
        email: data.get("email"),
        password: data.get("password"),
      }),
    });
    if (res.ok) {
      const body = (await res.json().catch(() => ({}))) as { twoFactorRedirect?: boolean };
      if (body.twoFactorRedirect) {
        // 2FA is on — swap to the code step instead of going home.
        form.hidden = true;
        twofaForm?.removeAttribute("hidden");
        twofaForm?.querySelector("input")?.focus();
      } else {
        window.location.href = "/";
      }
      return;
    }
    // The Turnstile token is single-use — reset the widget so the next attempt
    // gets a fresh challenge instead of resubmitting a spent/empty token.
    (window as unknown as { turnstile?: { reset?: () => void } }).turnstile?.reset?.();
    // 403 = the bot gate (Turnstile) rejected the request; 429 = rate limit.
    // Both carry a meaningful server message worth showing verbatim — only a
    // genuine 401 is actually "invalid email or password".
    const body = (await res.json().catch(() => ({}))) as { message?: string };
    if (res.status === 403 || res.status === 429) {
      showError(body.message ?? "Please complete the human verification challenge.");
    } else {
      showError("Invalid email or password.");
    }
  });

  const twofaForm = document.getElementById("twofa-form") as HTMLFormElement | null;
  const twofaErr = document.getElementById("twofa-error");
  twofaForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (twofaErr) twofaErr.hidden = true;
    const code = String(new FormData(twofaForm).get("code") ?? "").trim();
    const res = await fetch("/api/auth/two-factor/verify-totp", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ code }),
    });
    const ok = res.ok && ((await res.json().catch(() => ({}))) as { status?: boolean }).status !== false;
    if (ok) {
      window.location.href = "/";
    } else if (twofaErr) {
      twofaErr.hidden = false;
    }
  });
</script>

<style>
  .login {
    max-width: 380px;
    margin-inline: auto;
    width: 100%;
  }
  .login-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  /* Author display:flex would otherwise override the `hidden` attribute, so the
     2FA step (and the hidden login form during 2FA) must opt back into none. */
  .login-card[hidden] {
    display: none;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .field .label {
    font-size: 0.5rem;
    color: var(--lime);
  }
  .field input {
    background: var(--deep-moss);
    border: 2px solid var(--lime);
    color: var(--phosphor);
    padding: 0.6rem;
    font-family: inherit;
    font-size: 0.95rem;
  }
  .field input:focus {
    outline: none;
    border-color: var(--phosphor);
  }
  .error {
    color: #fca5a5;
    font-size: 0.5rem;
    margin: 0;
  }
  .hint {
    color: var(--lime);
    font-size: 0.5rem;
    line-height: 1.6;
    margin: 0;
  }
  .submit {
    text-align: center;
    cursor: pointer;
    margin-top: 0.25rem;
  }
  .forgot-link {
    font-size: 0.5rem;
    color: var(--lime);
    text-align: center;
  }
</style>
