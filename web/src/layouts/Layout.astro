---
// Base layout: retro neon-green pixel theme (palette from docs/legacy/Figmaprompt.md).
interface Props {
  title?: string;
  description?: string;
  center?: boolean;
  topShare?: number; // proportion of leftover space above the content (with `center`)
  bottomShare?: number; // proportion below — e.g. 1 / 3 puts content 25% from the top
}
const {
  title = "VRC6 — Alternate Lifestyle Publication",
  description = "VRC6 — interviews, events, games, and underground culture. A retro neon-green magazine.",
  center = false,
  topShare = 1,
  bottomShare = 1,
} = Astro.props;
const canonical = Astro.url.href;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body
    class={center ? "centered" : undefined}
    style={center ? `--top-share:${topShare};--bottom-share:${bottomShare}` : undefined}
  >
    <header class="site-header">
      <a class="logo pixel" href="/">VRC6</a>
      <button
        class="nav-toggle"
        id="nav-toggle"
        type="button"
        aria-label="Toggle menu"
        aria-controls="header-nav"
        aria-expanded="false"
      >
        <span></span><span></span><span></span>
      </button>
      <nav class="header-nav" id="header-nav">
        <a class="contact pixel" href="/contact">CONTACT US</a>
        {user && <a class="contact pixel" href="/dashboard">DASHBOARD</a>}
        {user?.role === "admin" && <a class="contact pixel" href="/admin">ADMIN</a>}
        {
          user ? (
            <button class="contact pixel" id="logout-btn" type="button">
              LOG OUT
            </button>
          ) : (
            <a class="contact pixel" href="/login">LOG IN</a>
          )
        }
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p class="pixel">VRC6 © {new Date().getFullYear()} — ALTERNATE LIFESTYLE PUBLICATION</p>
    </footer>

    <script>
      // Mobile nav: the hamburger toggles the collapsed menu.
      const navToggle = document.getElementById("nav-toggle");
      const headerNav = document.getElementById("header-nav");
      navToggle?.addEventListener("click", () => {
        const open = headerNav?.classList.toggle("open") ?? false;
        navToggle.setAttribute("aria-expanded", String(open));
      });

      document.getElementById("logout-btn")?.addEventListener("click", async () => {
        // better-auth needs a JSON content-type (else 415) AND a body it can
        // parse (an empty body is a 400) — send an empty object.
        await fetch("/api/auth/sign-out", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: "{}",
        });
        // Full reload so the server re-renders the header in the logged-out state.
        window.location.assign("/");
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --deep-moss: #052e16; /* background / shadows */
    --forest: #14532d; /* mid-tones */
    --lime: #4ade80; /* primary accents */
    --phosphor: #bbf7d0; /* highlight / text */
    --ink: #020c06; /* near-black for pixel-depth text shadows */
    --card-h: 165px; /* uniform article-card height */
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    background-color: var(--deep-moss);
    color: var(--phosphor);
    font-family: system-ui, -apple-system, sans-serif;
  }

  body {
    display: flex;
    flex-direction: column;
  }

  .pixel {
    font-family: "Press Start 2P", monospace;
    letter-spacing: 0.5px;
  }

  /* ---- Layout chrome ---- */
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background-color: var(--forest);
    border-bottom: 2px solid var(--lime);
  }
  .logo {
    font-family: "Press Start 2P", monospace;
    font-size: 1.5rem;
    color: var(--lime);
    text-decoration: none;
    text-shadow: 2px 2px 0 var(--phosphor);
  }
  .contact {
    font-size: 0.6rem;
    color: var(--deep-moss);
    background-color: var(--lime);
    padding: 0.6rem 0.9rem;
    text-decoration: none;
    border: 2px solid var(--phosphor);
    box-shadow: 3px 3px 0 var(--phosphor);
    white-space: nowrap;
  }
  .header-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.6rem;
  }
  button.contact {
    cursor: pointer;
    font-family: "Press Start 2P", monospace;
  }
  /* Hamburger toggle — hidden on desktop, shown on mobile. */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 8px 7px;
    background-color: var(--lime);
    border: 2px solid var(--phosphor);
    box-shadow: 3px 3px 0 var(--phosphor);
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 3px;
    background-color: var(--deep-moss);
  }
  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
    }
    /* Collapse the nav into a full-width dropdown, toggled by the hamburger. */
    .header-nav {
      display: none;
      flex-basis: 100%;
      flex-direction: column;
      align-items: stretch;
    }
    .header-nav.open {
      display: flex;
    }
    .header-nav .contact {
      text-align: center;
    }
  }
  .site-main {
    flex: 1;
    padding: 1.5rem;
    max-width: 1280px;
    width: 100%;
    margin: 0 auto;
  }
  .site-footer {
    padding: 0.9rem;
    text-align: center;
    background-color: var(--forest);
    border-top: 2px solid var(--lime);
  }
  .site-footer .pixel {
    font-size: 0.5rem;
    margin: 0;
    color: var(--phosphor);
  }

  /* ---- Shared component primitives (reused across pages) ---- */
  .card {
    display: block;
    border: 2px solid var(--lime);
    border-radius: 8px;
    padding: 1.25rem;
    background-color: var(--forest);
    box-shadow: 5px 5px 0 var(--phosphor);
    text-decoration: none;
    color: inherit;
    transition: transform 0.1s ease;
  }
  a.card:hover {
    transform: scale(1.02);
  }
  .card p {
    color: var(--lime);
    line-height: 1.6;
  }
  .card h2,
  .card h3 {
    color: var(--phosphor);
  }

  .tag,
  .cat {
    display: inline-block;
    align-self: flex-start; /* don't stretch when inside a flex-column card */
    background-color: var(--lime);
    color: var(--deep-moss);
    font-size: 0.5rem;
    padding: 0.35rem 0.6rem;
    margin-bottom: 0.6rem;
  }
  .cat {
    background-color: var(--deep-moss);
    color: var(--phosphor);
  }

  .chip {
    display: inline-block;
    background-color: var(--lime);
    color: var(--deep-moss);
    font-size: 0.4rem;
    padding: 0.35rem 0.5rem;
    text-decoration: none;
    transition: transform 0.1s ease;
  }
  a.chip:hover {
    transform: scale(1.05);
  }

  .btn {
    display: inline-block;
    background-color: var(--lime);
    color: var(--deep-moss);
    font-size: 0.5rem;
    padding: 0.6rem 0.9rem;
    border: 2px solid var(--phosphor);
    text-decoration: none;
  }

  /* ---- Page helpers (detail / category / stubs) ---- */
  .back {
    display: inline-block;
    font-size: 0.5rem;
    color: var(--lime);
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .page-title {
    font-size: 1.4rem;
    line-height: 1.6;
    color: var(--lime);
    text-shadow: 2px 2px 0 var(--ink);
    margin: 0 0 1rem;
  }
  .muted {
    color: var(--lime);
    font-size: 0.85rem;
  }
  .prose {
    max-width: 70ch;
  }
  .prose p {
    color: var(--phosphor);
    line-height: 1.9;
    margin: 0 0 1.1rem;
  }

  /* Opt-in: vertically center the content between header and footer on desktop
     (used by the homepage, whose bento fits one screen). Mobile stays top-aligned
     and scrolls naturally. */
  @media (min-width: 900px) {
    body.centered .site-main {
      display: flex;
      flex-direction: column;
    }
    /* Empty spacers split the leftover space in a configurable ratio; they
       collapse to 0 when the content is taller than the viewport (then it just
       scrolls). Default 1:1 = centered; 1:3 sits the content ~25% from the top. */
    body.centered .site-main::before {
      content: "";
      flex: var(--top-share, 1);
    }
    body.centered .site-main::after {
      content: "";
      flex: var(--bottom-share, 1);
    }
  }

  /* ---- Carousel gallery lightbox ----
     Created at runtime by lib/carousel-client.ts and appended to <body>, so it
     lives outside any page's scoped styles — it must be styled globally. Shared
     by the public article page and the editor's read-only preview. */
  .carousel-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: rgba(2, 12, 6, 0.92);
  }
  .carousel-lightbox[hidden] {
    display: none;
  }
  .carousel-lightbox .cl-img {
    max-width: 92vw;
    max-height: 86vh;
    object-fit: contain;
    border: 2px solid var(--lime);
    box-shadow: 4px 4px 0 var(--phosphor);
    background: var(--ink);
  }
  .carousel-lightbox button {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Press Start 2P", monospace;
    color: var(--deep-moss);
    background: var(--lime);
    border: 2px solid var(--phosphor);
    cursor: pointer;
  }
  .carousel-lightbox button[hidden] {
    display: none;
  }
  .carousel-lightbox .cl-close {
    top: 1rem;
    right: 1rem;
    width: 2.4rem;
    height: 2.4rem;
    font-size: 0.8rem;
  }
  .carousel-lightbox .cl-prev,
  .carousel-lightbox .cl-next {
    top: 50%;
    transform: translateY(-50%);
    width: 2.6rem;
    height: 3.2rem;
    font-size: 1.2rem;
  }
  .carousel-lightbox .cl-prev {
    left: 1rem;
  }
  .carousel-lightbox .cl-next {
    right: 1rem;
  }
  .carousel-lightbox .cl-counter {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: "Press Start 2P", monospace;
    font-size: 0.5rem;
    color: var(--lime);
  }
</style>
